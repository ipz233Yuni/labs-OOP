<Window x:Name="wpf" x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Лабораторна робота №2 Завдання №2" Height="441" Width="421" Background="#FFA6F5FF" MinWidth="600" MinHeight="500" MaxWidth="700" MaxHeight="600" WindowStartupLocation="CenterScreen" Loaded="wpf_Loaded">
    <Grid>
        <Label x:Name="label1" Content="Введіть послідовність чисел через кому:" HorizontalAlignment="Left" Height="35" Margin="10,10,0,0" VerticalAlignment="Top" Width="334" FontFamily="Times New Roman" FontSize="16" RenderTransformOrigin="0.471,0.517"/>
        <TextBox x:Name="TextBox1" Margin="10,45,47,0" TextWrapping="Wrap" FontFamily="Times New Roman" FontSize="16" Height="20" VerticalAlignment="Top"/>
        <Label x:Name="label2" Content="Довжина найбільшой підпослідовності:" HorizontalAlignment="Left" Height="35" Margin="10,126,0,0" VerticalAlignment="Top" Width="334" FontFamily="Times New Roman" FontSize="16" RenderTransformOrigin="0.471,0.517"/>
        <Label x:Name="label3" Content="Юр'єв Н.І. ІПЗ-23-3" HorizontalAlignment="Right" Height="35" Margin="0,0,10,10" VerticalAlignment="Bottom" Width="164" FontFamily="Times New Roman" FontSize="16" RenderTransformOrigin="0.5,0.5"/>
        <TextBox x:Name="TextBox2" Margin="10,166,47,0" TextWrapping="Wrap" FontFamily="Times New Roman" FontSize="16" Height="20" VerticalAlignment="Top" IsReadOnly="True"/>
        <Button x:Name="buttom" Content="Розрахунок" HorizontalAlignment="Left" Height="30" Margin="10,82,0,0" VerticalAlignment="Top" Width="238" Background="#FFF9B8B8" FontFamily="Times New Roman" FontSize="16" Click="buttom_Click"/>
        <Label x:Name="label4" Content="Довжина підпослідовності однакових чисел менша або рівна 2!" HorizontalAlignment="Center" Height="35" Margin="0,207,0,0" VerticalAlignment="Top" Width="476" FontFamily="Times New Roman" FontSize="16" RenderTransformOrigin="0.471,0.517" Visibility="Hidden"/>
        <Image x:Name="image" Margin="192,247,192,19" Source="/red-circle-emoji-clipart-md.png" Stretch="Fill" Visibility="Hidden"/>

    </Grid>
</Window>
